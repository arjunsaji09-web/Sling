rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "arjunsaji09@gmail.com" ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
                    (request.resource.data.role == 'user' || request.auth.token.email == "arjunsaji09@gmail.com");
      allow update: if isOwner(userId) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read, delete: if isAuthenticated() && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow create: if request.resource.data.text is string && request.resource.data.text.size() <= 1000;
    }
  }
}
