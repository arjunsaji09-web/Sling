rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "arjunsaji09@gmail.com");
    }

    function isRecent(timestamp) {
      return timestamp > request.time - duration.value(5, 'm');
    }

    match /users/{userId} {
      // ONLY the owner or admin can read the full profile (protects email)
      allow read: if isOwner(userId) || isAdmin();
      // Public can only read non-sensitive fields if we had a public collection, 
      // but for now, we'll keep it strict.
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read, delete: if isAuthenticated() && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow create: if request.resource.data.text is string 
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.recipientUid != request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /blocks/{blockId} {
      allow create, read, delete: if isAuthenticated() && blockId.startsWith(request.auth.uid);
      allow read, update, delete: if isAdmin();
    }
  }
}
